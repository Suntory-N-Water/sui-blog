---
import { Badge } from '@/components/ui/badge';
import { cn, formatDate } from '@/lib/utils';
import type { CollectionEntry } from 'astro:content';

type Props = {
  work: CollectionEntry<'works'>;
};

const { work } = Astro.props;
const { title, description, date, tags, thumbnail, siteUrl, githubUrl } =
  work.data;
const dateISO = date.toISOString();
const formattedDate = formatDate(date.getTime());
---

<style>
  .works-card-wrapper {
    position: relative;
  }
  .works-card-wrapper .works-site-link::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 10;
  }
  .works-card-wrapper .works-github-link {
    position: relative;
    z-index: 20;
  }
</style>

<div
  class={cn(
    'works-card-wrapper group flex h-full cursor-pointer flex-col overflow-hidden rounded-xl border border-border bg-card text-card-foreground shadow-sm transition-all duration-300',
    'hover:-translate-y-1 hover:border-primary/50 hover:shadow-md',
    'has-[.works-site-link:focus-visible]:ring-2 has-[.works-site-link:focus-visible]:ring-primary has-[.works-site-link:focus-visible]:ring-offset-2',
  )}
>
  <div class='relative aspect-video w-full bg-muted overflow-hidden'>
    <img
      src={thumbnail}
      alt={`${title} のスクリーンショット`}
      loading='lazy'
      decoding='async'
      class='h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-105'
    />
    <div
      class='absolute bottom-3 left-3 flex items-center gap-2 rounded bg-background/90 px-2 py-0.5 font-mono text-xs text-muted-foreground backdrop-blur'
    >
      <time datetime={dateISO}>{formattedDate}</time>
    </div>
  </div>

  <div class='flex flex-1 flex-col p-4 md:p-5'>
    <div class='mb-3 flex flex-wrap gap-2'>
      {
        tags.slice(0, 3).map((tag) => (
          <Badge
            variant='secondary'
            className='border border-border px-2 py-0.5 text-xs font-medium'
            client:load
          >
            {tag}
          </Badge>
        ))
      }
    </div>

    <h2
      class='mb-3 text-lg font-bold leading-[1.5] transition-colors group-hover:text-primary'
    >
      <a
        href={siteUrl}
        target='_blank'
        rel='noopener noreferrer'
        class='works-site-link no-underline outline-none'
      >
        {title}
      </a>
    </h2>

    {
      description && (
        <p class='mb-4 flex-1 text-sm leading-relaxed text-muted-foreground line-clamp-2'>
          {description}
        </p>
      )
    }

    <div
      class='mt-auto flex items-center justify-between border-t border-border pt-4'
    >
      <span
        class='text-xs font-bold text-muted-foreground transition-colors group-hover:text-foreground'
      >
        サイトを見る
      </span>
      <a
        href={githubUrl}
        target='_blank'
        rel='noopener noreferrer'
        class='works-github-link flex h-8 w-8 items-center justify-center rounded-full bg-secondary/50 text-foreground transition-colors hover:bg-primary hover:text-primary-foreground focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2'
        aria-label={`${title} の GitHub リポジトリ`}
      >
        <svg
          aria-hidden='true'
          xmlns='http://www.w3.org/2000/svg'
          viewBox='0 0 496 512'
          class='h-4 w-4'
          fill='currentColor'
        >
          <path
            d='M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3 .3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5 .3-6.2 2.3zm44.2-1.7c-2.9 .7-4.9 2.6-4.6 4.9 .3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8zM97.2 352.9c-1.3 1-1 3.3 .7 5.2 1.6 1.6 3.9 2.3 5.2 1 1.3-1 1-3.3-.7-5.2-1.6-1.6-3.9-2.3-5.2-1zm-10.8-8.1c-.7 1.3 .3 2.9 2.3 3.9 1.6 1 3.6 .7 4.3-.7 .7-1.3-.3-2.9-2.3-3.9-2-.6-3.6-.3-4.3 .7zm32.4 35.6c-1.6 1.3-1 4.3 1.3 6.2 2.3 2.3 5.2 2.6 6.5 1 1.3-1.3 .7-4.3-1.3-6.2-2.2-2.3-5.2-2.6-6.5-1zm-11.4-14.7c-1.6 1-1.6 3.6 0 5.9 1.6 2.3 4.3 3.3 5.6 2.3 1.6-1.3 1.6-3.9 0-6.2-1.4-2.3-4-3.3-5.6-2z'
          ></path>
        </svg>
      </a>
    </div>
  </div>
</div>
