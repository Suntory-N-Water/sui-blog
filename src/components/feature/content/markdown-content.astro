---
import { CodeCopyButtons } from './code-copy-buttons';
import { ImageZoom } from './image-zoom';
import { TwitterWidgets } from './twitter-widgets';

type Props = {
  html: string;
};

const { html } = Astro.props;
---

<div class='markdown-content' set:html={html} />

<CodeCopyButtons client:idle />
<ImageZoom client:idle />
<TwitterWidgets client:idle />
