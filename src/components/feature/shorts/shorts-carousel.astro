---
import type { CollectionEntry } from 'astro:content';
import ShortsCard from './shorts-card.astro';

type Props = {
  shorts: (CollectionEntry<'shorts'> & { body?: string })[];
};

const { shorts } = Astro.props;
---

<section class='py-6'>
  <div
    class='mb-6 flex items-baseline justify-between border-b border-border/60 pb-3 container mx-auto px-4'
  >
    <h2 class='text-2xl font-bold tracking-tight border-b-0 mb-0 pb-0'>
      Shorts
    </h2>
    <a
      href='/shorts'
      class='text-sm font-bold text-primary transition-colors hover:underline'
    >
      すべて見る
    </a>
  </div>

  <div
    class='flex gap-6 overflow-x-auto pb-8 pt-1 scrollbar-hide snap-x snap-mandatory'
  >
    {
      shorts.map((short) => (
        <div class='w-[280px] shrink-0 snap-start'>
          <ShortsCard short={short} />
        </div>
      ))
    }
  </div>
</section>
