---
import { cn } from '@/lib/utils';

type Props = {
  currentPage: number;
  totalPages: number;
  basePath: string;
};

const { currentPage, totalPages, basePath } = Astro.props;

const firstPagePath = basePath.split('/').slice(0, -1).join('/') || basePath;

const prevHref =
  currentPage <= 1
    ? null
    : currentPage === 2
      ? firstPagePath
      : `${basePath}/${currentPage - 1}`;

const nextHref =
  currentPage >= totalPages ? null : `${basePath}/${currentPage + 1}`;

const paginationPages = Array.from({ length: totalPages }, (_, i) => {
  const pageNumber = i + 1;
  return {
    number: pageNumber,
    url: pageNumber === 1 ? firstPagePath : `${basePath}/${pageNumber}`,
  };
});

const navButtonBase =
  'inline-flex items-center justify-center size-11 rounded-lg border border-border bg-background text-muted-foreground transition-colors';
const navButtonEnabled =
  'hover:border-primary/30 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring';
---

<nav
  class='flex items-center justify-center gap-3 py-8'
  aria-label='ページネーション'
>
  <div class='shrink-0'>
    {
      prevHref ? (
        <a href={prevHref} class={cn(navButtonBase, navButtonEnabled)}>
          <span class='sr-only'>前のページへ</span>
          <svg
            xmlns='http://www.w3.org/2000/svg'
            class='size-4'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            aria-hidden='true'
          >
            <path d='m15 18-6-6 6-6' />
          </svg>
        </a>
      ) : (
        <span class={cn(navButtonBase, 'opacity-40')} aria-hidden='true' />
      )
    }
  </div>

  <div class='relative min-w-0'>
    <label for='pagination-select' class='sr-only'>表示するページ</label>
    <select
      id='pagination-select'
      data-pagination-select
      class='w-36 sm:w-40 h-11 appearance-none rounded-lg border border-border bg-background px-4 pr-10 text-center text-sm font-medium tabular-nums text-muted-foreground cursor-pointer hover:border-primary/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring transition-colors'
    >
      {
        paginationPages.map((p) => (
          <option value={p.url} selected={p.number === currentPage}>
            {p.number} / {totalPages} ページ
          </option>
        ))
      }
    </select>
    <svg
      xmlns='http://www.w3.org/2000/svg'
      class='pointer-events-none absolute right-3 top-1/2 size-4 -translate-y-1/2 text-muted-foreground/60'
      viewBox='0 0 24 24'
      fill='none'
      stroke='currentColor'
      stroke-width='2'
      stroke-linecap='round'
      stroke-linejoin='round'
      aria-hidden='true'
    >
      <path d='m6 9 6 6 6-6'></path>
    </svg>
  </div>

  <div class='shrink-0'>
    {
      nextHref ? (
        <a href={nextHref} class={cn(navButtonBase, navButtonEnabled)}>
          <span class='sr-only'>次のページへ</span>
          <svg
            xmlns='http://www.w3.org/2000/svg'
            class='size-4'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            aria-hidden='true'
          >
            <path d='m9 18 6-6-6-6' />
          </svg>
        </a>
      ) : (
        <span class={cn(navButtonBase, 'opacity-40')} aria-hidden='true' />
      )
    }
  </div>
</nav>

<script>
  document.addEventListener('change', (event) => {
    const target = event.target;
    if (
      !(target instanceof HTMLSelectElement) ||
      !target.matches('[data-pagination-select]')
    ) {
      return;
    }
    if (target.value) {
      window.location.href = target.value;
    }
  });
</script>
